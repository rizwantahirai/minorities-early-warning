# Copy this file to `.streamlit/secrets.toml` for local runs.
# DO NOT COMMIT the real secrets.toml — it's already in .gitignore.
#
# On Streamlit Community Cloud you do NOT need this file at all.
# Instead, paste the same content into:
#   App page on share.streamlit.io
#     -> Settings (kebab menu)
#       -> Secrets
#         (paste the lines below, then Save)

username = "admin"
password = "change-me-to-a-strong-shared-password"
